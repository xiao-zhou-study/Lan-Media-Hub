{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Lan Media Hub",
  "version": "0.1.0",
  "identifier": "com.lanmediahub.app",
  "build": {
    "frontendDist": "../frontend/dist",
    "devUrl": "http://localhost:5200",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Lan Media Hub",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [],
    "resources": [],
    "copyright": "",
    "category": "Utility",
    "shortDescription": "局域网媒体共享",
    "longDescription": "专业级局域网媒体共享桌面软件"
  },
  "plugins": {}
}